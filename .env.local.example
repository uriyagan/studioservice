# Copy to .env.local and fill in. See README.md §3 for where each value comes from.
#
# ⚠️ Local dev points at the PRODUCTION Supabase — there is no separate dev
# project. Every local action touches real client data. See README.md §2.

# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — bypasses RLS entirely. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (email) ────────────────────────────────────────
# Leave EMPTY locally: lib/email/send.ts throws when the key is missing instead
# of sending, which keeps test emails away from real clients. Fill only if you
# genuinely need to test sending — and then send to yourself only.
RESEND_API_KEY=

# Optional — Svix verification for the delivery-status webhook. Not needed locally.
RESEND_WEBHOOK_SECRET=

# Optional — guards /api/email/inbound. Only needed to test inbound mail.
INBOUND_WEBHOOK_TOKEN=

# ── Stripe ────────────────────────────────────────────────
# Use TEST keys locally. Production runs LIVE — live keys here would charge
# real cards on every purchase test.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# From: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────
# Used for Stripe redirect URLs and webhooks. In production:
# https://service.uriyaganor.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — set to github.sha by the deploy workflow; falls back to "dev".
# NEXT_PUBLIC_BUILD_ID=
